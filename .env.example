# app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional production-only public base URL for AI provider webhooks.
# Leave empty in local development; local AI tasks can be refreshed via /api/ai/query.
AI_WEBHOOK_URL=
NEXT_PUBLIC_APP_NAME=RolePlay
NEXT_PUBLIC_APP_DESCRIPTION=
NEXT_PUBLIC_APP_LOGO=/logo.png
NEXT_PUBLIC_APP_FAVICON=/favicon.ico
NEXT_PUBLIC_APP_PREVIEW_IMAGE=/preview.png
NEXT_PUBLIC_DEFAULT_LOCALE=en

# theme
NEXT_PUBLIC_THEME=default

# appearance
NEXT_PUBLIC_APPEARANCE=system

# database
DATABASE_PROVIDER=postgresql
DATABASE_URL=
DB_SINGLETON_ENABLED=true
DB_MAX_CONNECTIONS=5
ROLEPLAY_DB_TIMEOUT_MS=10000
ROLEPLAY_DB_RETRIES=1
ROLEPLAY_DB_RETRY_DELAY_MS=180

# auth secret
# openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=
AUTH_TRUSTED_ORIGINS=

# chat / roleplay LLM
# Generic OpenAI-compatible config. Change these to swap provider/model without code changes.
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Backward-compatible OpenRouter aliases.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ROLEPLAY_MODEL=openai/gpt-4o-mini
ROLEPLAY_AUTO_MEMORY_EXTRACTION_ENABLED=true
ROLEPLAY_FACT_EXTRACTION_TIMEOUT_MS=18000

# Volcengine Ark aliases.
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_API_KEY=
VOLCENGINE_TEXT_VISION_TEXT_MODEL=
VOLCENGINE_TEXT_VISION_VISION_MODEL=
VOLCENGINE_GENERAL_IMAGE_MODEL=
VOLCENGINE_GENERAL_TTS_MODEL=doubao-seed-tts-2-0
VOLCENGINE_GENERAL_TTS_APPID=
VOLCENGINE_GENERAL_TTS_Access_Token=
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE_TYPE=zh_female_kailangjiejie_moon_bigtts

# Generic OpenAI-compatible image generation config.
IMAGE_GENERATION_PROVIDER=
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_BASE_URL=
IMAGE_GENERATION_MODEL=
IMAGE_GENERATION_SIZE=
ROLEPLAY_IMAGE_MODERATION_ENABLED=true
ROLEPLAY_IMAGE_STORAGE_MODE=upload
OPENROUTER_IMAGE_API_KEY=
OPENROUTER_IMAGE_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_IMAGE_MODEL=
XAI_IMAGE_API_KEY=
XAI_IMAGE_BASE_URL=https://api.x.ai/v1
XAI_IMAGE_MODEL=grok-imagine-image-quality

# ai media providers
KIE_API_KEY=
REPLICATE_API_TOKEN=
FAL_API_KEY=
GEMINI_API_KEY=

# storage, Cloudflare R2 recommended for roleplay avatars, gallery, voice assets
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_UPLOAD_PATH=roleplay
R2_ENDPOINT=
R2_DOMAIN=

# optional AWS S3 / S3-compatible storage fallback
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_DOMAIN=
